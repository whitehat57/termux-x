# ============================================================
# Termux-X Zsh Profile
# Cyberpunk terminal experience for Termux
# ============================================================

export TERMUX_X_HOME="__TERMUX_X_HOME__"
export LANG="${LANG:-en_US.UTF-8}"
export LC_ALL="${LC_ALL:-en_US.UTF-8}"
export EDITOR="${EDITOR:-nano}"

# History
HISTFILE="$HOME/.zsh_history"
HISTSIZE=5000
SAVEHIST=5000
setopt append_history
setopt share_history
setopt hist_ignore_dups
setopt hist_ignore_space
setopt hist_reduce_blanks
setopt inc_append_history

# Completion
autoload -Uz compinit
mkdir -p "$TERMUX_X_HOME/cache"
compinit -d "$TERMUX_X_HOME/cache/.zcompdump"
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# Key binding
bindkey -e

# Quality-of-life aliases
alias cls='clear'
alias tx='clear && [ -f "$TERMUX_X_HOME/banner.txt" ] && cat "$TERMUX_X_HOME/banner.txt"'
alias ll='ls -lah'
alias ..='cd ..'

# Startup UI: only render for interactive shell
if [[ -o interactive ]]; then
  clear

  if [ -f "$TERMUX_X_HOME/banner.txt" ]; then
    printf '\033[1;36m'
    cat "$TERMUX_X_HOME/banner.txt"
    printf '\033[0m'
  fi

  printf '\n'
  printf '\033[1;36mв•­в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®\033[0m\n'
  printf '\033[1;36mв”‚\033[0m              \033[1;35mTermux-X\033[0m                \033[1;36mв”‚\033[0m\n'
  printf '\033[1;36mв”њв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¤\033[0m\n'
  printf '\033[1;36mв”‚\033[0m Shell      : zsh                     \033[1;36mв”‚\033[0m\n'
  printf '\033[1;36mв”‚\033[0m Theme      : cyberpunk               \033[1;36mв”‚\033[0m\n'
  printf '\033[1;36mв”‚\033[0m UX Plugin  : autosuggest + syntax    \033[1;36mв”‚\033[0m\n'
  printf '\033[1;36mв•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї\033[0m\n'
  printf '\n'
fi

# Autosuggestions
if [ -f "$TERMUX_X_HOME/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
  ZSH_AUTOSUGGEST_STRATEGY=(history completion)
  ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8'
  source "$TERMUX_X_HOME/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh"
fi

# Prompt
PROMPT='%F{cyan}в•­в”Ђ[%F{magenta}Termux-X%F{cyan}]в”Ђ[%F{white}%~%F{cyan}]
в•°в”Ђ%F{magenta}вќЇ%f '

# Syntax highlighting must stay near the end of this file.
if [ -f "$TERMUX_X_HOME/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
  ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets pattern cursor)
  source "$TERMUX_X_HOME/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi
